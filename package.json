{
  "name": "fhirtogether-scheduling-synapse",
  "version": "1.0.0",
  "description": "FHIR-compliant gateway and test server for schedule and appointment availability",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && npm run build --prefix packages/fhir-scheduler",
    "build:server": "tsc",
    "start": "node dist/server.js",
    "generate-data": "tsx src/examples/generateBusyOffice.ts",
    "import-seed": "tsx src/examples/importSeedData.ts",
    "hl7-test": "tsx src/examples/testHL7.ts",
    "validate-smart": "tsx src/examples/validateSmartScheduling.ts",
    "test": "jest --forceExit && playwright test",
    "test:unit": "jest --forceExit",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:all": "jest --forceExit && playwright test && npm test --prefix packages/fhir-scheduler",
    "lint": "eslint src/"
  },
  "keywords": [
    "fhir",
    "hl7",
    "scheduling",
    "appointments",
    "healthcare"
  ],
  "author": "MieWeb",
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@fastify/static": "^9.1.3",
    "@fastify/swagger": "^9.0.0",
    "@fastify/swagger-ui": "^5.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^9.2.2",
    "dotenv": "^16.3.1",
    "fastify": "^5.8.5",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1",
    "rrule": "^2.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@playwright/test": "^1.59.1",
    "@types/better-sqlite3": "^7.6.8",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.10.6",
    "eslint": "^9.27.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.32.1"
  }
}
